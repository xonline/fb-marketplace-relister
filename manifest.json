{
  "manifest_version": 3,
  "name": "Relist for Facebook Marketplace",
  "version": "3.7.10",
  "description": "Relist your Facebook Marketplace listings in one click — single, bulk or scheduled. Keeps photos, price, location & condition.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "*://*.facebook.com/*",
    "https://upload.facebook.com/*",
    "https://*.fbcdn.net/*",
    "https://*.xx.fbcdn.net/*",
    "https://generativelanguage.googleapis.com/*",
    "https://relist.nowoly.com/*"
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.facebook.com/marketplace/you/selling*"],
      "js": ["harvest-inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://www.facebook.com/marketplace/you/selling*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Marketplace Relister",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "options_page": "options.html"
}
