{
  "manifest_version": 3,
  "name": "FB Marketplace Relister",
  "version": "2.0.2",
  "description": "Automatically relists Facebook Marketplace items to keep them fresh.",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.facebook.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.facebook.com/marketplace/*"],
      "js": ["hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://www.facebook.com/marketplace/*"],
      "js": ["utils.js", "drop_img.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FB Marketplace Relister"
  }
}
